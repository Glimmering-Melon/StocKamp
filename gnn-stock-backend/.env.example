# Neo4j Database Connection
# Bolt URI for the Neo4j instance (use bolt://neo4j:7687 when running via docker-compose)
NEO4J_URI=bolt://localhost:7687

# Neo4j authentication username
NEO4J_USER=neo4j

# Neo4j authentication password — change this before deploying
NEO4J_PASSWORD=changeme

# FastAPI server bind host (use 0.0.0.0 to accept connections from all interfaces)
API_HOST=0.0.0.0

# FastAPI server bind port
API_PORT=8000
