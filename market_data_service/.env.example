# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=

# Supabase service role key (NOT the anon key — used for write operations bypassing RLS)
SUPABASE_SERVICE_KEY=

# vnstock API key — register free at https://vnstocks.com/login (60 req/min)
# Leave empty to use guest tier (20 req/min)
VNSTOCK_API_KEY=
